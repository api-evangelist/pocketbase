    "url": "url",
    "documentation": "documentation",
    "provider": "provider",
    "version": "version",
    "license": "license",
    "programmingLanguage": "programmingLanguage",
    "collection": {
      "@id": "pocketbase:collection",
      "@type": "@id"
    },
    "record": {
      "@id": "pocketbase:record",
      "@type": "@id"
    },
    "authMethod": {
